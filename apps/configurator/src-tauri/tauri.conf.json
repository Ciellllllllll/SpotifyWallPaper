{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spotify Wallpaper Configurator",
  "version": "0.0.0",
  "identifier": "dev.spotify-wallpaper.configurator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Spotify Wallpaper Configurator",
        "width": 1180,
        "height": 820,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
